# .env
# =============================================================================
# LLM Configuration
# =============================================================================
LLM_MODEL=llama3.1
LLM_BASE_URL=http://localhost:11434

# =============================================================================
# API Credentials
# =============================================================================
# StockTwits API (Optional - public data works without keys)
STOCKTWITS_CLIENT_ID=
STOCKTWITS_CLIENT_SECRET=

# Reddit API (Optional - not currently used)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# NewsAPI (Optional backup)
NEWSAPI_KEY=

# =============================================================================
# Application Settings
# =============================================================================
DEFAULT_TRADING_STYLE=DAY_TRADING
DATABASE_PATH=database/market_data.db
AGENT_VERBOSE=False
AGENT_MAX_ITERATIONS=10

# =============================================================================
# ISO Financial MCP Configuration
# =============================================================================
ISO_MCP_CACHE_TTL=3600
ISO_MCP_TIMEOUT=30